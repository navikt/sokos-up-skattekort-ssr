---
import Layout from "@components/layout/Layout.astro";
import SkattekortForm from "@components/skattekort/SkattekortForm.astro";
import Skattekortvisning from "@components/skattekort/Skattekortvisning";
import { Alert, BodyLong, Heading } from "@navikt/ds-react";
import { actions, isInputError } from "astro:actions";
import styles from "./_index.module.css";
import commonStyles from "@components/skattekort/commonStyles.module.css";
import { getYearOptions } from "@utils/year";
import type { SkattekortData } from "@schema/SkattekortSchema";

const yearOptions = getYearOptions();
const actionResult = Astro.getActionResult(actions.skattekort.search);
const actionError = actionResult?.error;
const inputErrors =
  actionError && isInputError(actionError) ? actionError.fields : undefined;
const nonInputError =
  actionError && !isInputError(actionError) ? actionError : undefined;
const payload = actionResult?.data?.payload as SkattekortData | undefined;
const query = actionResult?.data?.query;

const hasResult = Array.isArray(payload) && payload.length > 0;
const firstEntry = hasResult ? payload[0] : undefined;
const arbeidsgivere = firstEntry?.arbeidsgiver ?? [];
const hasArbeidsgiver = arbeidsgivere.length > 0;

const defaultYear = yearOptions.at(-1) ?? new Date().getFullYear();
const resultName = firstEntry?.navn ?? "N.N.";

const showNoDataAlert =
  Boolean(actionResult) && (!payload || payload.length === 0);
const showNoSkattekort = Boolean(actionResult) && hasResult && !hasArbeidsgiver;
const showSkattekort = Boolean(actionResult) && hasArbeidsgiver;
---

<Layout>
  <div class={styles.page}>
    <div class={styles.header}>
      <Heading level="1" size="large">Skattekort</Heading>
    </div>

    <div class={styles.formWrapper}>
      <SkattekortForm
        defaultFnr={query?.fnr ?? ""}
        defaultYear={query?.year ?? defaultYear}
        yearOptions={yearOptions}
        fnrError={inputErrors?.fnr}
        yearError={inputErrors?.year}
      />
    </div>

    <div class={styles.resultContainer}>
      {
        nonInputError && (
          <Alert variant="error">
            {nonInputError.message ?? "En feil oppstod. Prøv igjen senere."}
          </Alert>
        )
      }

      {
        showNoDataAlert && (
          <Alert variant="warning">
            <div class={commonStyles.bold}>Ingen skattekort funnet</div>
          </Alert>
        )
      }

      {
        showNoSkattekort && (
          <>
            <hr class={commonStyles.separator} />
            <div class={styles.resultName}>{resultName}</div>
            <Alert variant="warning">
              <div class={commonStyles.bold}>Ingen skattekort funnet</div>
              <div>
                Vi fant ingen opplysninger om skattekort på dette
                fødselsnummeret.
              </div>
            </Alert>
          </>
        )
      }

      {
        showSkattekort && (
          <>
            <hr class={commonStyles.separator} />
            <div
              class={styles.resultName}
            >{`Søkeresultat for ${resultName}`}</div>
            <Skattekortvisning data={payload!} />
          </>
        )
      }
    </div>
  </div>
</Layout>
